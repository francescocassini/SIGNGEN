# Copy this file to .env and fill values.
# .env is git-ignored.

# Required for private dataset access
SOKE_HF_DATASET_REPO=Francesco77/soke-private-data
HF_TOKEN=hf_xxx_replace_me

# Host path to external dataset directory (mounted into container)
SOKE_DATA_ROOT_HOST=/home/cirillo/Desktop/SOKE_DATA
LOCAL_UID=1000
LOCAL_GID=1000

# Optional toggles
SOKE_AUTO_DOWNLOAD_DATASET=1
SOKE_TRAIN_CFG=configs/soke.yaml
SOKE_TEST_CFG=configs/soke_infer_complete.yaml
